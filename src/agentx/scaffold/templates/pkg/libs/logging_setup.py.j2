"""Logging setup for {{ spec.slug }}.

Keeps the console readable: your app logs at INFO, chatty third-party libraries
(HTTP clients, vector store, embedding/model downloads, MCP) at WARNING.

Override the app level with the ``LOG_LEVEL`` env var (DEBUG/INFO/WARNING/…).
"""
from __future__ import annotations

import logging
import os

# Third-party loggers that are noisy at INFO and rarely useful to end users.
_NOISY = (
    "httpx", "httpcore", "urllib3", "openai", "anthropic",
    "chromadb", "sentence_transformers", "transformers", "huggingface_hub",
    "langchain", "langchain_core", "langgraph", "mcp", "asyncio",
)

_configured = False


def setup_logging(level: str | None = None) -> None:
    """Configure root logging once; quiet the noisy third-party loggers.

    Safe to call multiple times (idempotent).
    """
    global _configured
    if _configured:
        return
    app_level = (level or os.getenv("LOG_LEVEL", "INFO")).upper()
    logging.basicConfig(
        level=getattr(logging, app_level, logging.INFO),
        format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
        datefmt="%H:%M:%S",
    )
    for name in _NOISY:
        logging.getLogger(name).setLevel(logging.WARNING)
    _configured = True
