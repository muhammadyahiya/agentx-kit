"""RAG knowledge base for {{ spec.slug }}.

Drop files into ``knowledge/`` (PDF, Excel, CSV, Word, TXT, MD) — they are
loaded, chunked with LangChain's RecursiveCharacterTextSplitter, embedded, and
indexed in {{ spec.vector_store | default('chroma') | upper }}.

Embeddings auto-select the best available provider:
  HuggingFace local → OpenAI → Ollama → keyword fallback (no embeddings needed)

Override via env vars:
  AGENTX_EMBEDDING_PROVIDER=huggingface   # or openai, cohere, ollama, …
  AGENTX_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
"""
from __future__ import annotations

import logging
from pathlib import Path

from agentx.rag import (
    RAGConfig,
    RagIndex,
    build_index_from_directory,
    make_retriever_tool,
)

logger = logging.getLogger(__name__)

_KNOWLEDGE_DIR = Path(__file__).resolve().parents[2] / "knowledge"
_PERSIST_DIR = ".{{ spec.vector_store | default('chroma') }}"

_RAG_CONFIG = RAGConfig(
    chunk_size=800,
    chunk_overlap=120,
    vector_store="{{ spec.vector_store | default('chroma') }}",
    persist_dir=_PERSIST_DIR,
)

_index: RagIndex | None = None


def _load_index() -> RagIndex:
    """Load all documents from knowledge/ and build a vector index."""
    if not _KNOWLEDGE_DIR.exists() or not any(_KNOWLEDGE_DIR.rglob("*")):
        logger.warning(
            "knowledge/ is empty — add PDF, Excel, CSV, or .txt files to enable RAG."
        )
        from agentx.rag import build_index_from_texts
        return build_index_from_texts(
            ["Placeholder — add documents to the knowledge/ folder."],
            config=_RAG_CONFIG,
        )

    return build_index_from_directory(
        _KNOWLEDGE_DIR,
        config=_RAG_CONFIG,
        glob="**/*",
    )


def get_index() -> RagIndex:
    """Return the singleton ``RagIndex``, building it on first call."""
    global _index
    if _index is None:
        logger.info("Building RAG index from %s …", _KNOWLEDGE_DIR)
        _index = _load_index()
        logger.info(
            "RAG index ready: %d chunks, store=%s",
            len(_index), _index.store_type,
        )
    return _index


def get_knowledge_tool():
    """Return a LangChain tool that searches the knowledge base."""
    return make_retriever_tool(get_index())
