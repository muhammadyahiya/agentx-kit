"""Tool assembly for the {{ spec.slug }} graph.

Tools are plain LangChain tools; the model binds to them and the graph's
ToolNode executes any tool calls. Add your own tools to ``get_tools()``.

``get_tools()`` is memoized with ``lru_cache`` so importing both ``nodes`` and
``graph`` (each of which needs the tool list) does not spawn MCP subprocesses or
rebuild the RAG index more than once.
"""
from __future__ import annotations

from functools import lru_cache

from agentx.tools import make_web_search_tool
{% if spec.use_rag %}from .rag import get_knowledge_tool
{% endif %}
{% if spec.use_mcp %}from pathlib import Path

from agentx.tools import load_mcp_tools
{% endif %}


@lru_cache(maxsize=1)
def get_tools() -> tuple:
    """Return the (cached) tool list available to the agent(s).

    Returns a tuple so the result is hashable/immutable; callers that need a
    list can wrap with ``list(get_tools())``.
    """
    tools = [make_web_search_tool()]
{% if spec.use_rag %}
    tools.append(get_knowledge_tool())
{% endif %}
{% if spec.use_mcp %}
    tools.extend(load_mcp_tools(Path(__file__).resolve().parents[2] / "mcp_servers.json"))
{% endif %}
    return tuple(tools)
