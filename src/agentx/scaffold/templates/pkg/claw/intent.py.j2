"""Intent classification for Claw.

A tiny, robust LLM classifier that maps an inbound message to one of a fixed set
of intents. Falls back to ``chat`` on any parsing/LLM error so the pipeline never
hard-fails on a classification miss.
"""
from __future__ import annotations

import json
import logging
from enum import Enum

from langchain_core.messages import SystemMessage

from ..utils.llm import get_model

logger = logging.getLogger(__name__)


class Intent(str, Enum):
    CHAT = "chat"              # normal question / conversation → agent graph
    SUMMARIZE = "summarize"    # summarise a thread / document
    VOICE = "voice"           # user wants a spoken reply
    OTHER = "other"


_SYSTEM = (
    "You are an intent classifier. Classify the user's message into exactly one "
    "of: chat, summarize, voice, other.\n"
    "- voice: they explicitly want a spoken / audio reply.\n"
    "- summarize: they want a summary of a thread or document.\n"
    "- chat: any normal question or request.\n"
    "- other: anything else.\n"
    'Reply with ONLY a JSON object: {"intent": "<one of the above>"}.'
)


def classify_intent(message: str) -> Intent:
    """Classify ``message`` into an :class:`Intent` (defaults to CHAT on error)."""
    try:
        resp = get_model(temperature=0).invoke([SystemMessage(_SYSTEM), {"role": "user", "content": message}])
        raw = (resp.content or "").strip()
        # Tolerate prose around the JSON.
        start, end = raw.find("{"), raw.rfind("}")
        if start != -1 and end != -1:
            value = json.loads(raw[start : end + 1]).get("intent", "chat")
        else:
            value = raw.lower()
        return Intent(value)
    except Exception:  # noqa: BLE001
        logger.debug("intent classification failed; defaulting to chat", exc_info=True)
        return Intent.CHAT


__all__ = ["Intent", "classify_intent"]
