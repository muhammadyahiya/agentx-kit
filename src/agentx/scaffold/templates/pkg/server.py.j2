"""FastAPI server for {{ spec.slug }} — REST + SSE streaming.

Run:  uv run uvicorn {{ pkg }}.server:app --reload --port 8000
Endpoints: GET /health, POST /chat, GET /chat/stream?message=...

Conversation memory is partitioned by ``session_id``: pass a stable id per user
to keep context across turns, or omit it to get a fresh, isolated conversation
every request. Requests without a session_id NEVER share history.
"""
from __future__ import annotations

import json
import logging
import uuid

from dotenv import load_dotenv
from fastapi import FastAPI
from fastapi.responses import StreamingResponse
from pydantic import BaseModel, Field

load_dotenv()
logging.basicConfig(level=logging.INFO)
{% if spec.observability %}
from .observability import init_observability

init_observability()
{% endif %}
{% if spec.use_cache %}
from agentx.cache import enable_caching

enable_caching()
{% endif %}
{% if spec.guardrails %}
from .guardrails import guard_input, guard_output
{% endif %}
{% if spec.framework == 'langgraph' %}
from .graph import arun_text, stream_text
{% else %}
import asyncio

from .crew import run_text
{% endif %}

app = FastAPI(title="{{ spec.slug }}", version="0.1.0")


class ChatIn(BaseModel):
    message: str = Field(..., min_length=1, max_length=8000, description="User message.")
    # Stable id to keep conversation memory across turns; blank → isolated.
    session_id: str = Field(default="", max_length=128)


def _session(session_id: str) -> str:
    return session_id or f"anon-{uuid.uuid4().hex}"


@app.get("/health")
def health() -> dict:
    return {"status": "ok", "service": "{{ spec.slug }}"}


@app.post("/chat")
async def chat(body: ChatIn) -> dict:
    message = body.message
{% if spec.guardrails %}
    message = guard_input(message).text
{% endif %}
{% if spec.framework == 'langgraph' %}
    reply = await arun_text(message, thread_id=_session(body.session_id))
{% else %}
    reply = await asyncio.to_thread(run_text, message, _session(body.session_id))
{% endif %}
{% if spec.guardrails %}
    reply = guard_output(reply).text
{% endif %}
    return {"reply": reply}


@app.get("/chat/stream")
def chat_stream(message: str, session_id: str = "") -> StreamingResponse:
    """Server-Sent Events stream of the reply, token-by-token."""
{% if spec.guardrails %}
    message = guard_input(message).text
{% endif %}
    thread_id = _session(session_id)

    async def _events():
{% if spec.framework == 'langgraph' %}
        async for token in stream_text(message, thread_id=thread_id):
            yield f"data: {json.dumps({'token': token})}\n\n"
{% else %}
        reply = await asyncio.to_thread(run_text, message, thread_id)
{% if spec.guardrails %}
        reply = guard_output(reply).text
{% endif %}
        for chunk in reply.split(" "):
            yield f"data: {json.dumps({'token': chunk + ' '})}\n\n"
{% endif %}
        yield "data: [DONE]\n\n"

    return StreamingResponse(_events(), media_type="text/event-stream")
