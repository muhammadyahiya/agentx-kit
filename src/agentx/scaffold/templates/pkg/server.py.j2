"""FastAPI server for {{ spec.slug }} — REST + SSE streaming.

Run:
    uv run uvicorn {{ pkg }}.server:app --reload --port 8000

Endpoints:
    GET    /livez             — liveness probe (always 200)
    GET    /readyz            — readiness probe (checks LLM provider)
    GET    /health            — deep health check (LLM + components)
    POST   /chat              — single-turn chat, returns {reply, session_id}
    GET    /chat/stream       — SSE stream of tokens
    GET    /sessions/{id}     — retrieve conversation history for a session
    DELETE /sessions/{id}     — clear a session
"""
from __future__ import annotations

import json
import logging
import uuid
from contextlib import asynccontextmanager

from dotenv import load_dotenv
from fastapi import FastAPI, HTTPException, Path as PathParam, Query
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import JSONResponse, StreamingResponse
from pydantic import BaseModel, Field

from .logging_setup import setup_logging

load_dotenv()
setup_logging()   # app at INFO, noisy third-party libs at WARNING
logger = logging.getLogger(__name__)
{% if spec.observability %}
from .observability import init_observability
{% endif %}
{% if spec.use_cache %}
from agentx.cache import enable_caching
{% endif %}
{% if spec.guardrails %}
from .guardrails import guard_input, guard_output
{% endif %}
{% if spec.framework == 'langgraph' %}
from .graph import arun_text, graph, stream_text
{% else %}
import asyncio

from .crew import run_text as _crew_run_text

async def arun_text(message: str, thread_id: str = "default", *, raise_errors: bool = False) -> str:  # type: ignore[misc]
    # CrewAI's run_text propagates exceptions; asyncio.to_thread re-raises them,
    # so the /chat handler's try/except turns a failure into an HTTP 500.
    return await asyncio.to_thread(_crew_run_text, message, thread_id)

async def stream_text(message: str, thread_id: str = "default", *, raise_errors: bool = False):  # type: ignore[misc]
    reply = await arun_text(message, thread_id, raise_errors=raise_errors)
{% if spec.guardrails %}
    reply = guard_output(reply).text
{% endif %}
    for chunk in reply.split(" "):
        yield chunk + " "

graph = None   # CrewAI does not expose a checkpointer; session APIs return 501
{% endif %}


# ── Lifespan ─────────────────────────────────────────────────────────────────

@asynccontextmanager
async def lifespan(app: FastAPI):
{% if spec.observability %}
    init_observability()
{% endif %}
{% if spec.use_cache %}
    enable_caching()
{% endif %}
    logger.info("{{ spec.slug }} server starting up")
    yield
    logger.info("{{ spec.slug }} server shutting down")


# ── App ───────────────────────────────────────────────────────────────────────

app = FastAPI(
    title="{{ spec.slug }}",
    version="0.1.0",
    description="AgentX-powered agent API.",
    lifespan=lifespan,
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)


# ── Helpers ───────────────────────────────────────────────────────────────────

def _new_session() -> str:
    return f"session-{uuid.uuid4().hex[:8]}"


def _config(thread_id: str) -> dict:
    return {"configurable": {"thread_id": thread_id}}


# ── Schemas ───────────────────────────────────────────────────────────────────

class ChatRequest(BaseModel):
    message: str = Field(..., min_length=1, max_length=16000, description="User message.")
    session_id: str = Field(
        default="",
        max_length=128,
        description="Stable session id for multi-turn memory. Blank → new session.",
    )


class ChatResponse(BaseModel):
    reply: str
    session_id: str


class SessionMessage(BaseModel):
    role: str
    content: str


class SessionHistory(BaseModel):
    session_id: str
    messages: list[SessionMessage]


class HealthComponent(BaseModel):
    name: str
    status: str            # "ok" | "degraded" | "error"
    detail: str = ""


class HealthResponse(BaseModel):
    status: str            # overall — "ok" | "degraded" | "error"
    service: str
    version: str
    components: list[HealthComponent]


# ── Routes: health ───────────────────────────────────────────────────────────

@app.get("/livez", tags=["system"])
async def livez() -> dict:
    """Shallow liveness probe — always 200 if the process is alive."""
    return {"status": "ok"}


async def _ping_provider() -> tuple[bool, str]:
    """Best-effort 1-token call to confirm the LLM provider is reachable.

    Returns ``(ok, detail)``. Kept cheap (max_tokens=1) and never raises.
    """
    try:
        from agentx import get_chat_model
        from langchain_core.messages import HumanMessage
        from .config import MODEL, PROVIDER

        llm = get_chat_model(PROVIDER, MODEL, max_tokens=1)
        await llm.ainvoke([HumanMessage("ping")])
        return True, f"{PROVIDER}/{MODEL} reachable"
    except Exception as exc:  # noqa: BLE001
        return False, f"provider unreachable: {exc}"


@app.get("/readyz", tags=["system"])
async def readyz(deep: bool = Query(default=False, description="Also ping the LLM provider.")) -> JSONResponse:
    """Readiness probe. ``?deep=true`` additionally pings the LLM provider.

    Kubernetes readiness: use the default (fast) check for frequent probes and
    ``?deep=true`` sparingly, since it makes a real (tiny) model call.
    """
{% if spec.framework == 'crewai' %}
    ready = True   # crew module import already succeeded
{% else %}
    ready = graph is not None
{% endif %}
    if ready and deep:
        ready, _ = await _ping_provider()
    code = 200 if ready else 503
    return JSONResponse(status_code=code, content={"status": "ready" if ready else "not_ready"})


@app.get("/health", response_model=HealthResponse, tags=["system"])
async def health(deep: bool = Query(default=False, description="Also ping the LLM provider.")) -> HealthResponse:
    """Deep health check. ``?deep=true`` verifies LLM provider reachability."""
    components: list[HealthComponent] = []

    # Component: graph / crew initialisation
{% if spec.framework == 'crewai' %}
    graph_ok = True   # crew module import already succeeded
{% else %}
    graph_ok = graph is not None
{% endif %}
    components.append(HealthComponent(
        name="graph",
        status="ok" if graph_ok else "error",
        detail="compiled" if graph_ok else "not initialised",
    ))

    # Component: LLM provider (only probed when deep=true — it's a real call).
    if deep:
        ok, detail = await _ping_provider()
        components.append(HealthComponent(
            name="llm_provider", status="ok" if ok else "error", detail=detail,
        ))

    overall = "ok" if all(c.status == "ok" for c in components) else "degraded"
    return HealthResponse(
        status=overall,
        service="{{ spec.slug }}",
        version="0.1.0",
        components=components,
    )


# ── Routes: chat ─────────────────────────────────────────────────────────────

@app.post("/chat", response_model=ChatResponse, tags=["chat"])
async def chat(body: ChatRequest) -> ChatResponse:
    """Single-turn chat. Returns the complete reply once the model finishes."""
    session_id = body.session_id or _new_session()
    message = body.message
{% if spec.guardrails %}
    try:
        message = guard_input(message).text
    except Exception as exc:
        raise HTTPException(status_code=400, detail=str(exc)) from exc
{% endif %}
    try:
        reply = await arun_text(message, thread_id=session_id, raise_errors=True)
    except Exception as exc:
        logger.exception("chat invocation failed")
        raise HTTPException(status_code=500, detail=f"Agent error: {exc}") from exc
{% if spec.guardrails %}
    reply = guard_output(reply).text
{% endif %}
    return ChatResponse(reply=reply, session_id=session_id)


@app.get("/chat/stream", tags=["chat"])
async def chat_stream(
    message: str = Query(..., min_length=1, description="User message."),
    session_id: str = Query(default="", description="Session id for memory continuity."),
) -> StreamingResponse:
    """Server-Sent Events stream — tokens arrive as they're generated."""
    sid = session_id or _new_session()
{% if spec.guardrails %}
    try:
        message = guard_input(message).text
    except Exception as exc:
        raise HTTPException(status_code=400, detail=str(exc)) from exc
{% endif %}

    async def _events():
        try:
            async for token in stream_text(message, thread_id=sid, raise_errors=True):
                if token:
                    yield f"data: {json.dumps({'token': token, 'session_id': sid})}\n\n"
        except Exception as exc:
            logger.exception("stream_text failed")
            # Structured error event (not a normal token) so clients can distinguish it.
            yield f"data: {json.dumps({'error': str(exc), 'session_id': sid})}\n\n"
        yield "data: [DONE]\n\n"

    return StreamingResponse(
        _events(),
        media_type="text/event-stream",
        headers={
            "Cache-Control": "no-cache",
            "X-Accel-Buffering": "no",
            "X-Session-Id": sid,
        },
    )


# ── Routes: sessions ─────────────────────────────────────────────────────────

@app.get("/sessions/{session_id}", response_model=SessionHistory, tags=["sessions"])
async def get_session(
    session_id: str = PathParam(..., max_length=128, description="Session id."),
) -> SessionHistory:
    """Retrieve the conversation history for a session (LangGraph checkpointer)."""
{% if spec.framework == 'crewai' %}
    raise HTTPException(status_code=501, detail="Session history not available for CrewAI framework.")
{% else %}
    if graph is None:
        raise HTTPException(status_code=503, detail="Graph not initialised.")
    try:
        state = await graph.aget_state(config=_config(session_id))
    except Exception as exc:
        logger.exception("get_state failed")
        raise HTTPException(status_code=500, detail=str(exc)) from exc

    messages_raw = (state.values or {}).get("messages") or []
    messages: list[SessionMessage] = []
    for m in messages_raw:
        role = getattr(m, "type", None) or getattr(m, "role", "unknown")
        content = getattr(m, "content", "")
        if isinstance(content, str):
            messages.append(SessionMessage(role=role, content=content))
    return SessionHistory(session_id=session_id, messages=messages)
{% endif %}


@app.delete("/sessions/{session_id}", status_code=204, tags=["sessions"])
async def delete_session(
    session_id: str = PathParam(..., max_length=128, description="Session id to clear."),
) -> None:
    """Clear the checkpointed state for a session."""
{% if spec.framework == 'crewai' %}
    raise HTTPException(status_code=501, detail="Session deletion not available for CrewAI framework.")
{% else %}
    if graph is None:
        raise HTTPException(status_code=503, detail="Graph not initialised.")
    checkpointer = getattr(graph, "checkpointer", None)
    if checkpointer is None:
        raise HTTPException(status_code=501, detail="Graph has no checkpointer configured.")
    try:
        # NOTE: aupdate_state({"messages": []}) does NOT clear history — the
        # messages channel uses the add_messages reducer, which appends, so an
        # empty list is a no-op. Delete the whole thread instead.
        if hasattr(checkpointer, "adelete_thread"):
            await checkpointer.adelete_thread(session_id)
        elif hasattr(checkpointer, "delete_thread"):
            checkpointer.delete_thread(session_id)
        else:
            raise HTTPException(
                status_code=501,
                detail="Checkpointer does not support deleting a thread.",
            )
    except HTTPException:
        raise
    except Exception as exc:  # noqa: BLE001
        logger.exception("delete_session failed")
        raise HTTPException(status_code=500, detail=str(exc)) from exc
{% endif %}
