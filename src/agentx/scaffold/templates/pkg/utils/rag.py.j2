"""RAG index for {{ spec.slug }}.

Drop files into ``knowledge/`` (PDF, Excel, CSV, Word, TXT, MD) — they are
loaded, chunked, embedded, and indexed in {{ spec.vector_store | default('chroma') | upper }}. Rebuild anytime with
``agentx rag build`` (or add files with ``agentx rag upload <file>``).
"""
from __future__ import annotations

import logging

from agentx.rag import RAGConfig, RagIndex, build_index_from_directory, build_index_from_texts

from ..config import PROJECT_ROOT
from .embeddings import get_embedding_config

logger = logging.getLogger(__name__)

_KNOWLEDGE_DIR = PROJECT_ROOT / "knowledge"
_PERSIST_DIR = str(PROJECT_ROOT / ".{{ spec.vector_store | default('chroma') }}")

_RAG_CONFIG = RAGConfig(
    chunk_size=800,
    chunk_overlap=120,
    vector_store="{{ spec.vector_store | default('chroma') }}",
    persist_dir=_PERSIST_DIR,
)

_index: RagIndex | None = None


def _load_index() -> RagIndex:
    emb = get_embedding_config()
    if not _KNOWLEDGE_DIR.exists() or not any(_KNOWLEDGE_DIR.rglob("*")):
        logger.warning(
            "knowledge/ is empty — add documents (or run `agentx rag upload <file>`) "
            "to enable retrieval. Using a placeholder index for now."
        )
        return build_index_from_texts(
            ["Placeholder — add documents to the knowledge/ folder."],
            config=_RAG_CONFIG,
            embedding_config=emb,
        )
    return build_index_from_directory(
        _KNOWLEDGE_DIR, config=_RAG_CONFIG, embedding_config=emb, glob="**/*"
    )


def get_index() -> RagIndex:
    """Return the singleton ``RagIndex``, building it on first call."""
    global _index
    if _index is None:
        logger.info("Building RAG index from %s …", _KNOWLEDGE_DIR)
        _index = _load_index()
        logger.info("RAG index ready: %d chunks, store=%s", len(_index), _index.store_type)
    return _index


__all__ = ["get_index"]
