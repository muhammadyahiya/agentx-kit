"""LangGraph workflow for {{ spec.slug }}.

Exposes a module-level compiled ``graph`` (the LangGraph convention, also picked
up by ``langgraph dev``) and a ``run_text`` helper for CLI/server use.
"""
from __future__ import annotations

import asyncio
import logging

from langgraph.checkpoint.memory import MemorySaver
from langgraph.graph import END, START, StateGraph

from .state import AgentState

logger = logging.getLogger(__name__)

# Bound how many node hops one turn may take (guards against supervisor↔worker
# or agent↔tools loops never terminating).
RECURSION_LIMIT = 25
{% if not multi_agent %}
from langgraph.prebuilt import ToolNode, tools_condition

from .nodes import call_model
from .tools import get_tools


def build_graph():
    """Build the ReAct agent graph: agent ⇄ tools, with checkpointed memory."""
    builder = StateGraph(AgentState)
    builder.add_node("agent", call_model)
    builder.add_node("tools", ToolNode(get_tools()))

    builder.add_edge(START, "agent")
    # If the model asked for a tool, go run it; otherwise finish.
    builder.add_conditional_edges("agent", tools_condition)
    builder.add_edge("tools", "agent")

    return builder.compile(checkpointer=MemorySaver())
{% else %}
from .nodes import WORKERS, make_worker, supervisor
from .prompts import resolved_system_prompts


def build_graph():
    """Build a supervisor multi-agent graph: supervisor routes to workers."""
    builder = StateGraph(AgentState)
    builder.add_node("supervisor", supervisor)
    for name, system_prompt in resolved_system_prompts().items():
        builder.add_node(name, make_worker(name, system_prompt))

    builder.add_edge(START, "supervisor")
    # Supervisor decides the next worker, or ends.
    builder.add_conditional_edges(
        "supervisor",
        lambda state: state.get("next", "FINISH"),
        {**{name: name for name in WORKERS}, "FINISH": END},
    )
    # Every worker reports back to the supervisor.
    for name in WORKERS:
        builder.add_edge(name, "supervisor")

    return builder.compile(checkpointer=MemorySaver())
{% endif %}


# Module-level compiled graph (import this, or run `langgraph dev`).
graph = build_graph()


def _config(thread_id: str) -> dict:
    return {"configurable": {"thread_id": thread_id}, "recursion_limit": RECURSION_LIMIT}


async def arun_text(message: str, thread_id: str = "default") -> str:
    """Async invoke the graph; return the final text reply.

    ``thread_id`` selects the conversation memory partition. Callers serving
    multiple users MUST pass a distinct id per user/session — otherwise everyone
    shares one conversation history (see server.py for how it's wired).

    The graph runs async so that async-only tools (e.g. MCP servers) work.
    """
    try:
        result = await graph.ainvoke(
            {"messages": [{"role": "user", "content": message}]}, config=_config(thread_id)
        )
    except Exception as exc:  # noqa: BLE001
        logger.exception("graph invocation failed")
        return f"Sorry, something went wrong: {exc}"
    messages = result.get("messages", [])
    return getattr(messages[-1], "content", "") if messages else ""


_loop: asyncio.AbstractEventLoop | None = None


def _sync_loop() -> asyncio.AbstractEventLoop:
    """A persistent loop for sync callers (CLI/evals).

    Reused across calls so stateful async resources (e.g. MCP stdio sessions)
    aren't bound to a loop that's already been closed — which is what happens if
    you ``asyncio.run(...)`` a fresh loop on every turn.
    """
    global _loop
    if _loop is None or _loop.is_closed():
        _loop = asyncio.new_event_loop()
    return _loop


def run_text(message: str, thread_id: str = "default") -> str:
    """Sync wrapper over :func:`arun_text` for CLI / sync callers.

    Do NOT call this from inside a running event loop (e.g. an async web
    handler) — ``await arun_text(...)`` there instead.
    """
    return _sync_loop().run_until_complete(arun_text(message, thread_id))


async def stream_text(message: str, thread_id: str = "default"):
    """Async-yield the reply token-by-token as the model produces it."""
    try:
        # ``subgraphs=True`` so tokens from worker sub-agents (ReAct subgraphs)
        # are streamed, not just top-level node output.
        async for _ns, (chunk, meta) in graph.astream(
            {"messages": [{"role": "user", "content": message}]},
            config=_config(thread_id),
            stream_mode="messages",
            subgraphs=True,
        ):
{% if multi_agent %}
            # Don't leak the supervisor's internal routing tokens to the user.
            if meta.get("langgraph_node") == "supervisor":
                continue
{% endif %}
            text = getattr(chunk, "content", "")
            if text:
                yield text
    except Exception as exc:  # noqa: BLE001
        logger.exception("graph streaming failed")
        yield f"Sorry, something went wrong: {exc}"
