"""LangGraph workflow for {{ spec.slug }}.

Assembles the compiled ``graph`` from the per-agent nodes in ``nodes/`` and
exposes ``run_text`` / ``arun_text`` / ``stream_text`` helpers.

{% if multi_agent %}Orchestration: {{ orchestration }}
{% if orchestration == "supervisor" %}  An LLM router (nodes/supervisor.py) picks which specialist acts next.{% endif %}
{% if orchestration == "sequential" %}  Agents run in order: {% for a in spec.agents %}{{ a.name }}{% if not loop.last %} → {% endif %}{% endfor %}.{% endif %}
{% if orchestration == "parallel" %}  All agents answer simultaneously; results are merged.{% endif %}
{% else %}Single ReAct agent (nodes/agent.py) ⇄ tools.
{% endif %}
"""
from __future__ import annotations

import asyncio
import logging

from langgraph.checkpoint.memory import MemorySaver
from langgraph.graph import END, START, StateGraph

from .state import AgentState

logger = logging.getLogger(__name__)

RECURSION_LIMIT = 25
{% if not multi_agent %}
from langgraph.prebuilt import ToolNode, tools_condition

from .nodes import call_model
from .utils.tools import get_tools


def build_graph():
    """ReAct agent graph: agent ⇄ tools loop, with checkpointed memory."""
    builder = StateGraph(AgentState)
    builder.add_node("agent", call_model)
    builder.add_node("tools", ToolNode(list(get_tools())))
    builder.add_edge(START, "agent")
    builder.add_conditional_edges("agent", tools_condition)
    builder.add_edge("tools", "agent")
    return builder.compile(checkpointer=MemorySaver())
{% elif orchestration == "supervisor" %}
from .nodes import NODES, WORKERS, supervisor


def build_graph():
    """Supervisor graph: an LLM router picks the next specialist each turn."""
    builder = StateGraph(AgentState)
    builder.add_node("supervisor", supervisor)
    for name, node in NODES.items():
        builder.add_node(name, node)
    builder.add_edge(START, "supervisor")
    builder.add_conditional_edges(
        "supervisor",
        lambda state: state.get("next", "FINISH"),
        {**{name: name for name in WORKERS}, "FINISH": END},
    )
    for name in WORKERS:
        builder.add_edge(name, "supervisor")
    return builder.compile(checkpointer=MemorySaver())
{% elif orchestration == "sequential" %}
from .nodes import NODES, WORKERS


def build_graph():
    """Sequential pipeline: agents run in order, each seeing prior output."""
    builder = StateGraph(AgentState)
    for name, node in NODES.items():
        builder.add_node(name, node)
    builder.add_edge(START, WORKERS[0])
    for i in range(len(WORKERS) - 1):
        builder.add_edge(WORKERS[i], WORKERS[i + 1])
    builder.add_edge(WORKERS[-1], END)
    return builder.compile(checkpointer=MemorySaver())
{% elif orchestration == "parallel" %}
from langchain_core.messages import AIMessage
from langgraph.types import Send

from .nodes import NODES, WORKERS


def _merge(state) -> dict:
    """Combine every worker's answer into one reply."""
    worker_msgs = [m for m in state["messages"] if getattr(m, "name", None) in set(WORKERS)]
    if not worker_msgs:
        return {}
    combined = "\n\n".join(f"**{m.name}**:\n{m.content}" for m in worker_msgs)
    return {"messages": [AIMessage(content=combined)]}


def _fan_out(state):
    return [Send(name, state) for name in WORKERS]


def build_graph():
    """Parallel graph: all agents answer simultaneously, then results merge."""
    builder = StateGraph(AgentState)
    for name, node in NODES.items():
        builder.add_node(name, node)
    builder.add_node("merge", _merge)
    builder.add_conditional_edges(START, _fan_out, WORKERS)
    for name in WORKERS:
        builder.add_edge(name, "merge")
    builder.add_edge("merge", END)
    return builder.compile(checkpointer=MemorySaver())
{% endif %}


graph = build_graph()


def _config(thread_id: str) -> dict:
    return {"configurable": {"thread_id": thread_id}, "recursion_limit": RECURSION_LIMIT}


async def arun_text(message: str, thread_id: str = "default", *, raise_errors: bool = False) -> str:
    """Async invoke the graph; runs async-only tools (MCP) correctly.

    Pass a unique ``thread_id`` per user/session. ``raise_errors=True`` re-raises
    so the API server can surface failures as HTTP 500.
    """
    try:
        result = await graph.ainvoke(
            {"messages": [{"role": "user", "content": message}]}, config=_config(thread_id)
        )
    except Exception as exc:  # noqa: BLE001
        logger.exception("graph invocation failed")
        if raise_errors:
            raise
        return f"Sorry, something went wrong: {exc}"
    messages = result.get("messages", [])
    return getattr(messages[-1], "content", "") if messages else ""


_loop: asyncio.AbstractEventLoop | None = None


def _sync_loop() -> asyncio.AbstractEventLoop:
    """Reuse one loop across calls so MCP stdio sessions survive multiple turns."""
    global _loop
    if _loop is None or _loop.is_closed():
        _loop = asyncio.new_event_loop()
    return _loop


def run_text(message: str, thread_id: str = "default") -> str:
    """Sync wrapper for CLI / REPL use. Do NOT call from an async context."""
    return _sync_loop().run_until_complete(arun_text(message, thread_id))


async def stream_text(message: str, thread_id: str = "default", *, raise_errors: bool = False):
    """Yield reply tokens as the model produces them.

    Only assistant (AI) tokens are streamed — tool call/result messages and the
    supervisor's routing tokens are filtered out so internal tool chatter (e.g.
    file-access errors) never leaks into the user-facing stream.
    """
    from langchain_core.messages import AIMessage, AIMessageChunk

    try:
        async for _ns, (chunk, meta) in graph.astream(
            {"messages": [{"role": "user", "content": message}]},
            config=_config(thread_id),
            stream_mode="messages",
            subgraphs=True,
        ):
{% if multi_agent and orchestration == "supervisor" %}
            if meta.get("langgraph_node") == "supervisor":
                continue
{% endif %}
            # Only stream assistant tokens (skip ToolMessage / HumanMessage etc.).
            if not isinstance(chunk, (AIMessage, AIMessageChunk)):
                continue
            content = getattr(chunk, "content", "")
            # Some providers emit content as a list of blocks; normalise to text.
            if isinstance(content, list):
                content = "".join(
                    b.get("text", "") if isinstance(b, dict) else str(b) for b in content
                )
            if content:
                yield content
    except Exception as exc:  # noqa: BLE001
        logger.exception("graph streaming failed")
        if raise_errors:
            raise
        yield f"Sorry, something went wrong: {exc}"
