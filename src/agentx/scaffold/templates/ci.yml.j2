name: CI

on:
  push:
    branches: [main]
  pull_request:

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
        with:
          python-version: "3.12"
      - name: Install
        run: uv pip install --system -e . pytest ruff
      - name: Lint
        run: ruff check . || true
      - name: Compile
        run: python -m compileall src
      - name: Tests
        run: pytest -q || echo "no tests yet"
{% if spec.evals %}

  evals:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
        with:
          python-version: "3.12"
      - name: Install
        run: uv pip install --system -e .
      - name: Run eval gate
        # Non-blocking: the eval harness needs a reachable model (an API key or a
        # local model server). Add your provider secret(s) below and drop
        # `continue-on-error` to make this a hard CI gate.
        continue-on-error: true
        env:
          AGENTX_PROVIDER: {{ spec.provider }}
          AGENTX_MODEL: {{ model }}
{% for v in provider_env %}
          {{ v }}: {% raw %}${{ secrets.{% endraw %}{{ v }}{% raw %} }}{% endraw %}
{% endfor %}
        run: python evals/run_evals.py
{% endif %}
