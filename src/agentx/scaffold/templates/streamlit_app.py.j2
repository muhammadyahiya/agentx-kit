"""Streamlit UI for {{ spec.slug }}.

Run:  uv run streamlit run streamlit_app.py

Features:
  • Chat with the agent (per-session memory){% if spec.use_voice %}
  • 🎤 Voice input (speak your question) and 🔊 spoken replies{% endif %}{% if spec.claw %}
  • Claw intent routing (chat / summarize{% if spec.use_voice %} / voice{% endif %}){% endif %}
"""
from __future__ import annotations

import uuid

import streamlit as st
from dotenv import load_dotenv

load_dotenv()

{% if spec.framework == 'langgraph' %}from {{ pkg }}.graph import run_text
{% else %}from {{ pkg }}.crew import run_text
{% endif %}
{% if spec.use_voice %}from {{ pkg }}.libs.voice import speech_to_text, text_to_speech
{% endif %}

st.set_page_config(page_title="{{ spec.slug }}", page_icon="🧬", layout="centered")
st.title("🧬 {{ spec.slug }}")

# One conversation thread per browser session.
if "session_id" not in st.session_state:
    st.session_state.session_id = f"st-{uuid.uuid4().hex[:8]}"
if "history" not in st.session_state:
    st.session_state.history = []   # list[tuple[role, text]]

with st.sidebar:
    st.caption("Session: `%s`" % st.session_state.session_id)
{% if spec.use_voice %}
    speak = st.toggle("🔊 Speak replies", value=False)
{% else %}
    speak = False
{% endif %}
    if st.button("New conversation"):
        st.session_state.session_id = f"st-{uuid.uuid4().hex[:8]}"
        st.session_state.history = []
        st.rerun()

# Replay history.
for role, text in st.session_state.history:
    with st.chat_message(role):
        st.markdown(text)


def _respond(user_text: str) -> None:
    st.session_state.history.append(("user", user_text))
    with st.chat_message("user"):
        st.markdown(user_text)
    with st.chat_message("assistant"):
        with st.spinner("Thinking…"):
            reply = run_text(user_text, thread_id=st.session_state.session_id)
        st.markdown(reply)
{% if spec.use_voice %}
        if speak:
            try:
                st.audio(text_to_speech(reply), format="audio/mp3")
            except Exception as exc:  # noqa: BLE001
                st.caption(f"(voice synthesis unavailable: {exc})")
{% endif %}
    st.session_state.history.append(("assistant", reply))

{% if spec.use_voice %}
# 🎤 Voice input — record, transcribe, then answer.
audio = st.audio_input("🎤 Ask by voice")
if audio is not None and st.session_state.get("_last_audio") != audio.file_id:
    st.session_state["_last_audio"] = audio.file_id
    with st.spinner("Transcribing…"):
        try:
            transcript = speech_to_text(audio.getvalue())
        except Exception as exc:  # noqa: BLE001
            transcript = ""
            st.warning(f"Transcription failed: {exc}")
    if transcript:
        _respond(transcript)
{% endif %}

# Text input.
if prompt := st.chat_input("Type a message…"):
    _respond(prompt)
