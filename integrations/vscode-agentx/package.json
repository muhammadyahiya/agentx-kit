{
  "name": "agentx-kit",
  "displayName": "AgentX Kit",
  "description": "Scaffold, visualize, and run AgentX agentic projects (LangGraph / CrewAI) from VS Code — multi-agent orchestration, sub-agents, voice, and the Claw assistant.",
  "version": "0.2.0",
  "publisher": "optimumai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammadyahiya/agentx-kit"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Machine Learning"],
  "keywords": ["agents", "langgraph", "crewai", "llm", "rag", "agentx"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "agentx.new", "title": "AgentX: New Project…" },
      { "command": "agentx.graph", "title": "AgentX: Show Graph" },
      { "command": "agentx.dashboard", "title": "AgentX: Launch Dashboard" },
      { "command": "agentx.run", "title": "AgentX: Run Project" },
      { "command": "agentx.providers", "title": "AgentX: List Providers" }
    ],
    "menus": {
      "explorer/context": [
        { "command": "agentx.graph", "when": "explorerResourceIsFolder", "group": "agentx" }
      ]
    },
    "configuration": {
      "title": "AgentX",
      "properties": {
        "agentx.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the agentx executable. Empty = auto-detect (.venv/bin/agentx, then PATH)."
        }
      }
    }
  }
}
